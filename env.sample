# SEFAZ-MG Monitor — Configuração de Notificações
# Copie para /opt/sefaz-monitor/.env e preencha os valores

# --- E-mail (SMTP) ---
#SEFAZ_SMTP_HOST=smtp.gmail.com
#SEFAZ_SMTP_PORT=587
#SEFAZ_SMTP_USER=
#SEFAZ_SMTP_PASS=
#SEFAZ_MAIL_FROM=
#SEFAZ_MAIL_TO=

# --- Telegram ---
#SEFAZ_TELEGRAM_TOKEN=
#SEFAZ_TELEGRAM_CHAT_ID=

# --- Webhook (Slack/Discord) ---
#SEFAZ_WEBHOOK_URL=
